0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0acd\u0a9f\u0acb\u0ab0 \u0a95\u0acd\u0aaf\u0abe\u0a82 \u0a86\u0ab5\u0ac7\u0ab2\u0ac0 \u0a9b\u0ac7?"],"Tell us a bit about your store":["\u0a85\u0aae\u0aa8\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0ab8\u0acd\u0a9f\u0acb\u0ab0 \u0ab5\u0abf\u0ab6\u0ac7 \u0aa5\u0acb\u0aa1\u0ac1\u0a82 \u0a9c\u0aa3\u0abe\u0ab5\u0acb"],"Our favorite color is purple ":["\u0a85\u0aae\u0abe\u0ab0\u0acb \u0aaa\u0acd\u0ab0\u0abf\u0aaf \u0ab0\u0a82\u0a97 \u0a9c\u0abe\u0a82\u0aac\u0ab2\u0ac0 \u0a9b\u0ac7 "],"Shipping issues":["\u0ab6\u0abf\u0aaa\u0abf\u0a82\u0a97 \u0ab8\u0aae\u0ab8\u0acd\u0aaf\u0abe\u0a93"],"We\u2019ll use this information to help you set up payments, shipping, and taxes, as well as recommending the best theme for your store.":["\u0a85\u0aae\u0ac7 \u0a86 \u0aae\u0abe\u0ab9\u0abf\u0aa4\u0ac0\u0aa8\u0acb \u0a89\u0aaa\u0aaf\u0acb\u0a97 \u0aa4\u0aae\u0aa8\u0ac7 \u0a9a\u0ac1\u0a95\u0ab5\u0aa3\u0ac0\u0a93, \u0ab6\u0abf\u0aaa\u0abf\u0a82\u0a97 \u0a85\u0aa8\u0ac7 \u0a9f\u0ac7\u0a95\u0acd\u0ab8 \u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0ab5\u0abe\u0aae\u0abe\u0a82 \u0aa4\u0ac7\u0aae\u0a9c \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0ab8\u0acd\u0a9f\u0acb\u0ab0 \u0aae\u0abe\u0a9f\u0ac7 \u0ab6\u0acd\u0ab0\u0ac7\u0ab7\u0acd\u0aa0 \u0aa5\u0ac0\u0aae\u0aa8\u0ac0 \u0aad\u0ab2\u0abe\u0aae\u0aa3 \u0a95\u0ab0\u0ab5\u0abe\u0aae\u0abe\u0a82 \u0aae\u0aa6\u0aa6 \u0a95\u0ab0\u0ab5\u0abe \u0aae\u0abe\u0a9f\u0ac7 \u0a95\u0ab0\u0ac0\u0ab6\u0ac1\u0a82."],"Oops! We encountered a problem while installing %s. {{link}}Please try again{{\/link}}.":["\u0a85\u0ab0\u0ac7\u0ab0\u0ac7! %s \u0a87\u0aa8\u0acd\u0ab8\u0acd\u0a9f\u0acb\u0ab2 \u0a95\u0ab0\u0aa4\u0ac0 \u0ab5\u0a96\u0aa4\u0ac7 \u0a85\u0aae\u0aa8\u0ac7 \u0a8f\u0a95 \u0ab8\u0aae\u0ab8\u0acd\u0aaf\u0abe \u0a86\u0ab5\u0ac0. {{link}}\u0a95\u0ac3\u0aaa\u0abe \u0a95\u0ab0\u0ac0\u0aa8\u0ac7 \u0aab\u0ab0\u0ac0 \u0aaa\u0acd\u0ab0\u0aaf\u0abe\u0ab8 \u0a95\u0ab0\u0acb{{\/link}}."],"It looks like you\u2019re located in <geolocatedCountry><\/geolocatedCountry>. Are you sure you want to create a store in <selectedCountry><\/selectedCountry>?":["\u0a8f\u0ab5\u0ac1\u0a82 \u0ab2\u0abe\u0a97\u0ac7 \u0a9b\u0ac7 \u0a95\u0ac7 \u0aa4\u0aae\u0ac7 <geolocatedCountry><\/geolocatedCountry> \u0aae\u0abe\u0a82 \u0ab8\u0acd\u0aa5\u0abf\u0aa4 \u0a9b\u0acb. \u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0a96\u0ab0\u0ac7\u0a96\u0ab0 <selectedCountry><\/selectedCountry> \u0aae\u0abe\u0a82 \u0ab8\u0acd\u0a9f\u0acb\u0ab0 \u0aac\u0aa8\u0abe\u0ab5\u0ab5\u0abe \u0aae\u0abe\u0a82\u0a97\u0acb \u0a9b\u0acb?"],"Select an industry":["\u0a89\u0aa6\u0acd\u0aaf\u0acb\u0a97 \u0aaa\u0ab8\u0a82\u0aa6 \u0a95\u0ab0\u0acb"],"Don\u2019t worry \u2014 you can always change it later!":["\u0a9a\u0abf\u0a82\u0aa4\u0abe \u0a95\u0ab0\u0ab6\u0acb \u0aa8\u0ab9\u0ac0\u0a82 \u2014 \u0aa4\u0aae\u0ac7 \u0aa4\u0ac7\u0aa8\u0ac7 \u0aaa\u0a9b\u0ac0\u0aa5\u0ac0 \u0ab9\u0a82\u0aae\u0ac7\u0ab6\u0abe \u0aac\u0aa6\u0ab2\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb!"],"Ex. My awesome store":["\u0a89\u0aa6\u0abe\u0ab9\u0ab0\u0aa3 \u0aa4\u0ab0\u0ac0\u0a95\u0ac7, \u0aae\u0abe\u0ab0\u0acb \u0a85\u0aa6\u0acd\u0aad\u0ac1\u0aa4 \u0ab8\u0acd\u0a9f\u0acb\u0ab0"],"Opening the doors":["\u0aa6\u0ab0\u0ab5\u0abe\u0a9c\u0abe \u0a96\u0acb\u0ab2\u0ab5\u0abe"],"Did you know that Woo was founded by two South Africans and a Norwegian? Here are three alternative ways to say \u201cstore\u201d in those countries \u2013 Winkel, ivenkile, and butikk.":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0a9c\u0abe\u0aa3\u0acb \u0a9b\u0acb \u0a95\u0ac7 \u0ab5\u0ac2\u0aa8\u0ac0 \u0ab8\u0acd\u0aa5\u0abe\u0aaa\u0aa8\u0abe \u0aac\u0ac7 \u0aa6\u0a95\u0acd\u0ab7\u0abf\u0aa3 \u0a86\u0aab\u0acd\u0ab0\u0abf\u0a95\u0aa8\u0acb \u0a85\u0aa8\u0ac7 \u0a8f\u0a95 \u0aa8\u0acb\u0ab0\u0acd\u0ab5\u0ac7\u0a9c\u0ac0\u0aaf\u0aa8 \u0aa6\u0acd\u0ab5\u0abe\u0ab0\u0abe \u0a95\u0ab0\u0ab5\u0abe\u0aae\u0abe\u0a82 \u0a86\u0ab5\u0ac0 \u0ab9\u0aa4\u0ac0? \u0a85\u0ab9\u0ac0\u0a82 \u0aa4\u0ac7 \u0aa6\u0ac7\u0ab6\u0acb\u0aae\u0abe\u0a82 \"\u0ab8\u0acd\u0a9f\u0acb\u0ab0\" \u0a95\u0ab9\u0ac7\u0ab5\u0abe\u0aa8\u0abe \u0aa4\u0acd\u0ab0\u0aa3 \u0ab5\u0ac8\u0a95\u0ab2\u0acd\u0aaa\u0abf\u0a95 \u0ab0\u0ab8\u0acd\u0aa4\u0abe\u0a93 \u0a9b\u0ac7 - \u0ab5\u0abf\u0a82\u0a95\u0ac7\u0ab2, \u0a87\u0ab5\u0ac7\u0aa8\u0a95\u0ac0\u0ab2 \u0a85\u0aa8\u0ac7 \u0aac\u0ac1\u0a9f\u0abf\u0a95."],"Setting up your store in the wrong country may lead to the following issues:":["\u0a96\u0acb\u0a9f\u0abe \u0aa6\u0ac7\u0ab6\u0aae\u0abe\u0a82 \u0aa4\u0aae\u0abe\u0ab0\u0acb \u0ab8\u0acd\u0a9f\u0acb\u0ab0 \u0ab8\u0acd\u0aa5\u0abe\u0aaa\u0ab5\u0abe\u0aa5\u0ac0 \u0aa8\u0ac0\u0a9a\u0ac7\u0aa8\u0ac0 \u0ab8\u0aae\u0ab8\u0acd\u0aaf\u0abe\u0a93 \u0aa5\u0a88 \u0ab6\u0a95\u0ac7 \u0a9b\u0ac7:"],"Did you know that Woo powers almost 4 million stores worldwide? You\u2019re in good company.":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0a9c\u0abe\u0aa3\u0acb \u0a9b\u0acb \u0a95\u0ac7 \u0ab5\u0ac2\u0a95\u0acb\u0aae\u0ab0\u0acd\u0ab8 \u0ab5\u0abf\u0ab6\u0acd\u0ab5\u0aad\u0ab0\u0aae\u0abe\u0a82 \u0ab2\u0a97\u0aad\u0a97 4 \u0aae\u0abf\u0ab2\u0abf\u0aaf\u0aa8 \u0ab8\u0acd\u0a9f\u0acb\u0ab0\u0acd\u0ab8\u0aa8\u0ac7 \u0aaa\u0abe\u0ab5\u0ab0 \u0a95\u0ab0\u0ac7 \u0a9b\u0ac7? \u0aa4\u0aae\u0ac7 \u0ab8\u0abe\u0ab0\u0ac0 \u0a95\u0a82\u0aaa\u0aa8\u0ac0\u0aae\u0abe\u0a82 \u0a9b\u0acb."],"Woo! Let\u2019s get your features ready":["\u0ab5\u0abe\u0ab9! \u0a9a\u0abe\u0ab2\u0acb \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0ac1\u0ab5\u0abf\u0aa7\u0abe\u0a93 \u0aa4\u0ac8\u0aaf\u0abe\u0ab0 \u0a95\u0ab0\u0ac0\u0a8f"],"Which industry is your business in?":["\u0aa4\u0aae\u0abe\u0ab0\u0acb \u0ab5\u0acd\u0aaf\u0ab5\u0ab8\u0abe\u0aaf \u0a95\u0aaf\u0abe \u0a89\u0aa6\u0acd\u0aaf\u0acb\u0a97\u0aae\u0abe\u0a82 \u0a9b\u0ac7?"],"Clothing and accessories":["\u0a95\u0aaa\u0aa1\u0abe\u0a82 \u0a85\u0aa8\u0ac7 \u0a8f\u0ab8\u0ac7\u0ab8\u0ab0\u0ac0\u0a9d"],"What type of products or services do you plan to sell?":["\u0aa4\u0aae\u0ac7 \u0a95\u0aaf\u0abe \u0aaa\u0acd\u0ab0\u0a95\u0abe\u0ab0\u0aa8\u0abe\u0a82 \u0aaa\u0acd\u0ab0\u0acb\u0aa1\u0a95\u0acd\u0a9f\u0acd\u0ab8 \u0a85\u0aa5\u0ab5\u0abe \u0ab8\u0ac7\u0ab5\u0abe\u0a93 \u0ab5\u0ac7\u0a9a\u0ab5\u0abe\u0aa8\u0ac0 \u0aaf\u0acb\u0a9c\u0aa8\u0abe \u0aac\u0aa8\u0abe\u0ab5\u0ac0 \u0ab0\u0ab9\u0aaf\u0abe \u0a9b\u0acb?"],"Extending your store\u2019s capabilities":["\u0aa4\u0aae\u0abe\u0ab0\u0abe \u0ab8\u0acd\u0a9f\u0acb\u0ab0\u0aa8\u0ac0 \u0a95\u0acd\u0ab7\u0aae\u0aa4\u0abe\u0a93\u0aa8\u0acb \u0ab5\u0abf\u0ab8\u0acd\u0aa4\u0abe\u0ab0 \u0a95\u0ab0\u0ab5\u0acb"],"Which industry is your client\u2019s business in?":["\u0aa4\u0aae\u0abe\u0ab0\u0abe \u0a95\u0acd\u0ab2\u0abe\u0aaf\u0aa8\u0acd\u0a9f\u0aa8\u0acb \u0ab5\u0acd\u0aaf\u0ab5\u0ab8\u0abe\u0aaf \u0a95\u0aaf\u0abe \u0a89\u0aa6\u0acd\u0aaf\u0acb\u0a97\u0aae\u0abe\u0a82 \u0a9b\u0ac7?"],"Home, furniture and garden":["\u0a98\u0ab0, \u0aab\u0ab0\u0acd\u0aa8\u0abf\u0a9a\u0ab0 \u0a85\u0aa8\u0ac7 \u0aac\u0a97\u0ac0\u0a9a\u0acb"],"Select country\/region":["\u0aa6\u0ac7\u0ab6\/\u0aaa\u0acd\u0ab0\u0aa6\u0ac7\u0ab6 \u0aaa\u0ab8\u0a82\u0aa6 \u0a95\u0ab0\u0acb"],"Which platform(s) are you currently using?":["\u0aa4\u0aae\u0ac7 \u0ab9\u0abe\u0ab2\u0aae\u0abe\u0a82 \u0a95\u0aaf\u0abe \u0aaa\u0acd\u0ab2\u0ac7\u0a9f\u0aab\u0acb\u0ab0\u0acd\u0aae\u0aa8\u0acb \u0a89\u0aaa\u0aaf\u0acb\u0a97 \u0a95\u0ab0\u0ac0 \u0ab0\u0ab9\u0acd\u0aaf\u0abe\u0a82 \u0a9b\u0acb?"],"Are you selling online?":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0a93\u0aa8\u0ab2\u0abe\u0a88\u0aa8 \u0ab5\u0ac7\u0a9a\u0abe\u0aa3 \u0a95\u0ab0\u0acb \u0a9b\u0acb?"],"Let us know where you are in your commerce journey so that we can tailor your Woo experience for you.":["\u0a85\u0aae\u0aa8\u0ac7 \u0a9c\u0aa3\u0abe\u0ab5\u0acb \u0a95\u0ac7 \u0aa4\u0aae\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab5\u0abe\u0aa3\u0abf\u0a9c\u0acd\u0aaf \u0aaf\u0abe\u0aa4\u0acd\u0ab0\u0abe\u0aae\u0abe\u0a82 \u0a95\u0acd\u0aaf\u0abe\u0a82 \u0a9b\u0acb \u0a9c\u0ac7\u0aa5\u0ac0 \u0a95\u0ab0\u0ac0\u0aa8\u0ac7 \u0a85\u0aae\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0ab5\u0ac1 \u0a85