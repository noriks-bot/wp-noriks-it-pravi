a5\u0ac7, \u0aa4\u0aae\u0ac7 \u0a8f\u0a95 \u0a9c \u0a9c\u0a97\u0acd\u0aaf\u0abe\u0a8f\u0aa5\u0ac0 \u0a91\u0aa8\u0ab2\u0abe\u0a87\u0aa8 \u0a85\u0aa8\u0ac7 \u0ab5\u0acd\u0aaf\u0a95\u0acd\u0aa4\u0abf\u0a97\u0aa4 \u0ab0\u0ac0\u0aa4\u0ac7 \u0a9a\u0ac1\u0a95\u0ab5\u0aa3\u0ac0\u0a93 \u0ab8\u0acd\u0ab5\u0ac0\u0a95\u0abe\u0ab0\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb, \u0a86\u0ab5\u0a95 \u0a9f\u0acd\u0ab0\u0ac7\u0a95 \u0a95\u0ab0\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb \u0a85\u0aa8\u0ac7 \u0aac\u0aa7\u0ac0 \u0a9a\u0ac1\u0a95\u0ab5\u0aa3\u0ac0 \u0aaa\u0acd\u0ab0\u0ab5\u0ac3\u0aa4\u0acd\u0aa4\u0abf\u0aa8\u0ac7 \u0ab9\u0ac7\u0aa8\u0acd\u0aa1\u0ab2 \u0a95\u0ab0\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb."],"Enabling":["\u0ab8\u0a95\u0acd\u0ab7\u0aae \u0a95\u0ab0\u0ac0 \u0ab0\u0ab9\u0acd\u0aaf\u0ac1\u0a82 \u0a9b\u0ac7"],"Enable %s":["%s \u0ab8\u0a95\u0acd\u0ab7\u0aae \u0a95\u0ab0\u0acb"],"You need to reset your test account to continue onboarding with %1$s. This will create a new test account and reset any existing %2$s account details and test transactions.":["%1$s \u0ab8\u0abe\u0aa5\u0ac7 \u0a93\u0aa8\u0aac\u0acb\u0ab0\u0acd\u0aa1\u0abf\u0a82\u0a97 \u0a9a\u0abe\u0ab2\u0ac1 \u0ab0\u0abe\u0a96\u0ab5\u0abe \u0aae\u0abe\u0a9f\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0a9f\u0ac7\u0ab8\u0acd\u0a9f \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f\u0aa8\u0ac7 \u0ab0\u0ac0\u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0ab5\u0abe\u0aa8\u0ac0 \u0a9c\u0ab0\u0ac2\u0ab0 \u0a9b\u0ac7. \u0a86 \u0a8f\u0a95 \u0aa8\u0ab5\u0ac1\u0a82 \u0a9f\u0ac7\u0ab8\u0acd\u0a9f \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0aac\u0aa8\u0abe\u0ab5\u0ab6\u0ac7 \u0a85\u0aa8\u0ac7 \u0a95\u0acb\u0a88\u0aaa\u0aa3 \u0ab9\u0abe\u0ab2\u0aa8\u0abe %2$s \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0ab5\u0abf\u0a97\u0aa4\u0acb \u0a85\u0aa8\u0ac7 \u0a9f\u0ac7\u0ab8\u0acd\u0a9f \u0ab5\u0acd\u0aaf\u0ab5\u0ab9\u0abe\u0ab0\u0acb\u0aa8\u0ac7 \u0ab0\u0ac0\u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0ab6\u0ac7."],"Step %1$s of %2$s":["%2$s \u0aae\u0abe\u0a82\u0aa5\u0ac0 %1$s \u0aaa\u0a97\u0ab2\u0ac1\u0a82"],"Close sidebar":["\u0ab8\u0abe\u0a87\u0aa1\u0aac\u0abe\u0ab0 \u0aac\u0a82\u0aa7 \u0a95\u0ab0\u0acb"],"When you reset your account, all payment data \u2014 including your %s account details, test transactions, and payouts history \u2014 will be lost. Your order history will remain. This action cannot be undone, but you can create a new test account at any time.":["\u0a9c\u0acd\u0aaf\u0abe\u0ab0\u0ac7 \u0aa4\u0aae\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac1\u0a82 \u0a96\u0abe\u0aa4\u0ac1\u0a82 \u0ab0\u0ac0\u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0ab6\u0acb, \u0aa4\u0acd\u0aaf\u0abe\u0ab0\u0ac7 \u0aa4\u0aae\u0abe\u0aae \u0a9a\u0ac1\u0a95\u0ab5\u0aa3\u0ac0 \u0aa1\u0ac7\u0a9f\u0abe \u2014 \u0a9c\u0ac7\u0aae\u0abe\u0a82 \u0aa4\u0aae\u0abe\u0ab0\u0abe %s \u0a96\u0abe\u0aa4\u0abe \u0ab5\u0abf\u0a97\u0aa4\u0acb, \u0aaa\u0ab0\u0ac0\u0a95\u0acd\u0ab7\u0aa3 \u0ab2\u0ac7\u0aa8\u0aa6\u0ac7\u0aa8, \u0a85\u0aa8\u0ac7 \u0a9a\u0ac1\u0a95\u0ab5\u0aa3\u0ac0 \u0a87\u0aa4\u0abf\u0ab9\u0abe\u0ab8 \u0ab6\u0abe\u0aae\u0ac7\u0ab2 \u0a9b\u0ac7 \u2014 \u0a97\u0ac1\u0aae \u0aa5\u0a88 \u0a9c\u0ab6\u0ac7. \u0aa4\u0aae\u0abe\u0ab0\u0ac1\u0a82 \u0a93\u0ab0\u0acd\u0aa1\u0ab0 \u0a87\u0aa4\u0abf\u0ab9\u0abe\u0ab8 \u0aaf\u0aa5\u0abe\u0ab5\u0aa4 \u0ab0\u0ab9\u0ac7\u0ab6\u0ac7. \u0a86 \u0a95\u0acd\u0ab0\u0abf\u0aaf\u0abe \u0aaa\u0abe\u0a9b\u0ac0 \u0aab\u0ac7\u0ab0\u0ab5\u0ac0 \u0ab6\u0a95\u0abe\u0aaf \u0aa8\u0ab9\u0ac0\u0a82, \u0aaa\u0ab0\u0a82\u0aa4\u0ac1 \u0aa4\u0aae\u0ac7 \u0a95\u0acb\u0a88\u0aaa\u0aa3 \u0ab8\u0aae\u0aaf\u0ac7 \u0aa8\u0ab5\u0ac1\u0a82 \u0aaa\u0ab0\u0ac0\u0a95\u0acd\u0ab7\u0aa3 \u0a96\u0abe\u0aa4\u0ac1\u0a82 \u0aac\u0aa8\u0abe\u0ab5\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb."],"Installing":["\u0a87\u0aa8\u0acd\u0ab8\u0acd\u0a9f\u0acb\u0ab2 \u0a95\u0ab0\u0ac0 \u0ab0\u0ab9\u0acd\u0aaf\u0ac1\u0a82 \u0a9b\u0ac7"],"Yes, reset account":["\u0ab9\u0abe, \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0ab0\u0ac0\u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0acb"],"Are you sure you'd like to continue?":["\u0ab6\u0ac1\u0a82 \u0aa4\u0aae\u0ac7 \u0a96\u0ab0\u0ac7\u0a96\u0ab0 \u0a9a\u0abe\u0ab2\u0ac1 \u0ab0\u0abe\u0a96\u0ab5\u0abe \u0aae\u0abe\u0a82\u0a97\u0acb \u0a9b\u0acb?"],"When you reset your test account, all payment data \u2014 including your %s account details, test transactions, and payouts history \u2014 will be lost. Your order history will remain. This action cannot be undone, but you can create a new test account at any time.":["\u0a9c\u0acd\u0aaf\u0abe\u0ab0\u0ac7 \u0aa4\u0aae\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac1\u0a82 \u0a9f\u0ac7\u0ab8\u0acd\u0a9f \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0ab0\u0ac0\u0ab8\u0ac7\u0a9f \u0a95\u0ab0\u0acb \u0a9b\u0acb, \u0aa4\u0acd\u0aaf\u0abe\u0ab0\u0ac7 \u0aa4\u0aae\u0abe\u0aae \u0a9a\u0ac1\u0a95\u0ab5\u0aa3\u0ac0 \u0aa1\u0ac7\u0a9f\u0abe \u2014 \u0aa4\u0aae\u0abe\u0ab0\u0abe %s \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f\u0aa8\u0ac0 \u0ab5\u0abf\u0a97\u0aa4\u0acb, \u0aaa\u0ab0\u0ac0\u0a95\u0acd\u0ab7\u0aa3 \u0ab5\u0acd\u0aaf\u0ab5\u0ab9\u0abe\u0ab0\u0acb \u0a85\u0aa8\u0ac7 \u0a9a\u0ac2\u0a95\u0ab5\u0aa3\u0ac0\u0aa8\u0acb \u0a87\u0aa4\u0abf\u0ab9\u0abe\u0ab8 \u0ab8\u0ab9\u0abf\u0aa4 \u2014 \u0a96\u0acb\u0ab5\u0abe\u0a88 \u0a9c\u0ab6\u0ac7. \u0aa4\u0aae\u0abe\u0ab0\u0acb \u0a93\u0ab0\u0acd\u0aa1\u0ab0 \u0a87\u0aa4\u0abf\u0ab9\u0abe\u0ab8 \u0ab0\u0ab9\u0ac7\u0ab6\u0ac7. \u0a86 \u0a95\u0acd\u0ab0\u0abf\u0aaf\u0abe \u0aaa\u0ac2\u0ab0\u0acd\u0ab5\u0ab5\u0aa4\u0acd \u0a95\u0ab0\u0ac0 \u0ab6\u0a95\u0abe\u0aa4\u0ac0 \u0aa8\u0aa5\u0ac0, \u0aaa\u0ab0\u0a82\u0aa4\u0ac1 \u0aa4\u0aae\u0ac7 \u0a95\u0acb\u0a88\u0aaa\u0aa3 \u0ab8\u0aae\u0aaf\u0ac7 \u0aa8\u0ab5\u0ac1\u0a82 \u0aaa\u0ab0\u0ac0\u0a95\u0acd\u0ab7\u0aa3 \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0aac\u0aa8\u0abe\u0ab5\u0ac0 \u0ab6\u0a95\u0acb \u0a9b\u0acb."],"Reset your test account":["\u0aa4\u0aae\u0abe\u0ab0\u0ac1\u0a82 \u0a9f\u0ac7\u0ab8\u0acd\u0a9f \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0ab0\u0ac0\u0ab8\u0ac7\u0a9f \u0a95\u0a